{
  "name": "digiscript-electron",
  "version": "0.30.8",
  "description": "DigiScript Electron Desktop Application",
  "author": "DreamTeamProd",
  "license": "GPL-3.0",
  "main": "dist/main.js",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "tsc && electron .",
    "dev": "tsc && electron . --dev",
    "typecheck": "tsc --noEmit",
    "package": "tsc && electron-forge package",
    "make": "tsc && electron-forge make",
    "build": "cd ../client && BUILD_TARGET=electron npm run build && cd ../electron && npm run make",
    "lint": "npm run format && npm run lint:eslint",
    "lint:eslint": "eslint '**/*.{ts,cts}' --fix",
    "ci-lint": "npm run format:check && npm run lint:eslint-check",
    "lint:eslint-check": "eslint '**/*.{ts,cts}'",
    "format": "prettier --write '**/*.{ts,cts,json}'",
    "format:check": "prettier --check '**/*.{ts,cts,json}'"
  },
  "engines": {
    "npm": ">=11.0.0 <12",
    "node": ">=24.0.0 <25"
  },
  "dependencies": {
    "electron-store": "^11.0.2",
    "bonjour-service": "^1.4.0"
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@eslint/js": "^9.39.2",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@types/node": "^22.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "name": "DigiScript",
        "executableName": "digiscript",
        "icon": "./assets/icon",
        "asar": true,
        "extraResource": [
          "../client/dist-electron"
        ]
      },
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "platforms": [
            "win32"
          ],
          "config": {
            "name": "DigiScript",
            "authors": "DreamTeamProd",
            "exe": "digiscript.exe"
          }
        },
        {
          "name": "@electron-forge/maker-zip",
          "platforms": [
            "darwin"
          ]
        },
        {
          "name": "@electron-forge/maker-deb",
          "platforms": [
            "linux"
          ],
          "config": {
            "bin": "digiscript",
            "maintainer": "DreamTeamProd"
          }
        },
        {
          "name": "@electron-forge/maker-rpm",
          "platforms": [
            "linux"
          ],
          "config": {
            "bin": "digiscript",
            "vendor": "DreamTeamProd"
          }
        }
      ]
    }
  }
}
