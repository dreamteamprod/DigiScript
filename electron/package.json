{
  "name": "digiscript-electron",
  "version": "0.24.1",
  "description": "DigiScript Electron Desktop Application",
  "author": "DreamTeamProd",
  "license": "GPL-3.0",
  "main": "main.js",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "build": "cd ../client && BUILD_TARGET=electron npm run build && cd ../electron && npm run make",
    "lint": "npm run format && npm run lint:eslint",
    "lint:eslint": "eslint '**/*.{js,cjs}' --fix",
    "ci-lint": "npm run format:check && npm run lint:eslint-check",
    "lint:eslint-check": "eslint '**/*.{js,cjs}'",
    "format": "prettier --write '**/*.{js,cjs,json}'",
    "format:check": "prettier --check '**/*.{js,cjs,json}'"
  },
  "engines": {
    "npm": ">=11.0.0 <12",
    "node": ">=24.0.0 <25"
  },
  "dependencies": {
    "electron-store": "^11.0.2",
    "bonjour-service": "^1.3.0"
  },
  "devDependencies": {
    "electron": "^40.0.0",
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.1.0",
    "prettier": "^3.8.1"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "name": "DigiScript",
        "executableName": "digiscript",
        "icon": "./assets/icon",
        "asar": true,
        "extraResource": [
          "../client/dist-electron"
        ]
      },
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "name": "DigiScript",
            "authors": "DreamTeamProd",
            "exe": "digiscript.exe"
          }
        },
        {
          "name": "@electron-forge/maker-zip",
          "platforms": [
            "darwin"
          ]
        },
        {
          "name": "@electron-forge/maker-deb",
          "config": {
            "bin": "digiscript",
            "maintainer": "DreamTeamProd"
          }
        },
        {
          "name": "@electron-forge/maker-rpm",
          "config": {
            "bin": "digiscript",
            "vendor": "DreamTeamProd"
          }
        }
      ]
    }
  }
}
